{
  "name": "Java 25",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "JAVA_VERSION": "25.0.2-open",
      "MAVEN_VERSION": "3.9.16"
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "postCreateCommand": "bash -lc 'source $HOME/.sdkman/bin/sdkman-init.sh && sdk version && java --version && mvn --version && git lfs version && gh --version'",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.java",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-maven",
        "vscjava.vscode-java-test"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-25",
            "path": "/home/vscode/.sdkman/candidates/java/current",
            "default": true
          }
        ]
      }
    }
  }
}
